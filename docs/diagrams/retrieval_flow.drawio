                    <mxGeometry x="860" y="1185" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="fusion_rrf" value="Reciprocal Rank Fusion (RRF)&#xa;score = Σ 1/(k + rank_i), k=60 default&#xa;— rank-based, no score normalization needed —" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e65100;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="280" y="1290" width="400" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="fusion_weighted" value="Weighted Score Fusion&#xa;score = α·norm(dense) + (1-α)·norm(sparse)&#xa;— requires min-max or z-score normalization —" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e65100;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="780" y="1290" width="400" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="fusion_cascade" value="Cascade&#xa;search sparse only if dense&#xa;result count below threshold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e65100;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="1290" width="280" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="fusion_dedup" value="Deduplicate by chunk_id  →  merged, ranked candidate list (typically 30–60 chunks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=12;fontStyle=1;" parent="1" vertex="1">

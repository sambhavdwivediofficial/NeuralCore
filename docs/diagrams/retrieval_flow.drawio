                    <mxGeometry x="980" y="945" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sparse_topn" value="Top-N×2 candidates&#xa;(IDF-weighted term overlap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c2185b;fontSize=11;" parent="1" vertex="1">

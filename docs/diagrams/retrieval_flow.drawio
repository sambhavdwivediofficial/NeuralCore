                <mxCell id="consumer_eval" value="Evaluation Harness&#xa;(precision/recall scoring)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" parent="1" vertex="1">

                <mxCell id="dense_filter_pre" value="Pre-Filter Application&#xa;(metadata filter pushed into&#xa;ANN search if highly selective)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;dashed=1;" parent="1" vertex="1">

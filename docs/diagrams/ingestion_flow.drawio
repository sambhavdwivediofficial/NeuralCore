                    <mxGeometry x="390" y="2545" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s9_sparse" value="Sparse BM25 Vector Build&#xa;(tokenize + term-frequency,&#xa;for hybrid search support)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#01579b;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="680" y="2545" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s9_cache_check" value="Semantic Cache Check&#xa;(skip API call if identical&#xa;text embedded recently)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#01579b;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="970" y="2545" width="260" height="65" as="geometry"/>
                </mxCell>

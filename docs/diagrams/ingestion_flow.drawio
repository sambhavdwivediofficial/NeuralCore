                    <mxGeometry x="60" y="1460" width="1880" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="s5_hash" value="Compute Content Hash&#xa;(SHA-256 of normalized text,&#xa;not raw bytes — survives re-export)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b71c1c;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="1505" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s5_lookup" value="Lookup Existing Document&#xa;by (kb_id, source_uri, content_hash)&#xa;in PostgreSQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b71c1c;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="430" y="1505" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s5_decision" value="Hash Unchanged&#xa;from Last Ingest?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b71c1c;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="780" y="1495" width="180" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="s5_skip" value="SKIP — return existing&#xa;chunk references, mark job&#xa;completed (no re-embed cost)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#b71c1c;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="1450" width="280" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s5_versioning" value="If changed: mark previous&#xa;version superseded, create&#xa;new document_version row" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b71c1c;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="1530" width="280" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s5_orphan_check" value="Cross-Document Near-Duplicate&#xa;Check (different source, same&#xa;content — flag, don&#39;t auto-skip)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b71c1c;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="1505" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s5_continue" value="Continue to Chunking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b71c1c;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1660" y="1505" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="stage6" value="STAGE 6 — Chunking  (strategy selected per knowledge_base.chunking config)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;dashed=1;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1670" width="1880" height="370" as="geometry"/>
                </mxCell>
                <mxCell id="s6_select" value="Strategy Selector" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="900" y="1715" width="180" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="s6_fixed" value="Fixed&#xa;N tokens, overlap K&#xa;(simple, fast, default fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="100" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_recursive" value="Recursive&#xa;paragraph → sentence →&#xa;word, respects natural breaks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="340" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_semantic" value="Semantic&#xa;embed sentences, split at&#xa;similarity valleys (cosine drop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="580" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_markdown" value="Markdown&#xa;heading-based, preserves&#xa;document hierarchy in metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="820" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_code" value="Code&#xa;function/class level via&#xa;AST symbol boundaries (Stage 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_page" value="Page&#xa;one chunk per PDF page&#xa;(preserves page_number metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_table" value="Table-Aware&#xa;tables never split mid-row,&#xa;serialized as markdown table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="1540" y="1825" width="220" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_custom" value="Custom&#xa;user-supplied delimiter&#xa;regex / callback function" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=9;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1780" y="1825" width="160" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s6_overlap" value="Apply chunk_overlap&#xa;(shared context window&#xa;between adjacent chunks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="300" y="1920" width="280" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s6_prepend" value="Prepend Document Title&#xa;/ Section Heading&#xa;(per chunking config flags)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="610" y="1920" width="280" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s6_size_validate" value="Size Validation&#xa;(min/max chunk token count,&#xa;merge tiny trailing chunks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="920" y="1920" width="280" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s6_id_assign" value="Assign chunk_id + Ordinal&#xa;(stable IDs derived from&#xa;doc_id + chunk_index)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57f17;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="1920" width="280" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="stage7" value="STAGE 7 — Metadata Enrichment  (per-chunk, mostly LLM/NLP-assisted)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#283593;dashed=1;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;" parent="1" vertex="1">
                    <mxGeometry x="60" y="2060" width="1880" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="s7_lang" value="Per-Chunk Language Tag&#xa;(inherited from doc-level&#xa;unless chunk is mixed-language)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#283593;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="2105" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s7_entity" value="Entity Extraction&#xa;(spaCy NER — people, orgs,&#xa;dates, products → metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#283593;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="390" y="2105" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s7_topic" value="Topic Classification&#xa;(zero-shot classifier against&#xa;project-defined topic taxonomy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#283593;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="680" y="2105" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s7_summary" value="Auto-Summary Generation&#xa;(gpt-4o-mini, 1-sentence gist&#xa;stored for preview/debug UI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#283593;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="970" y="2105" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s7_custom_meta" value="Custom Metadata Merge&#xa;(user-supplied at upload time&#xa;+ path-pattern extraction)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#283593;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="2105" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s7_acl" value="ACL / Permission Metadata&#xa;(from connector — allowed_groups,&#xa;allowed_users, visibility)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#283593;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1550" y="2105" width="260" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="stage8" value="STAGE 8 — Chunk-Level Near-Duplicate Detection" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fbe9e7;strokeColor=#d84315;dashed=1;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=15;" parent="1" vertex="1">
                    <mxGeometry x="60" y="2300" width="1880" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="s8_minhash" value="MinHash Signature&#xa;(cheap pre-filter before&#xa;expensive embedding comparison)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d84315;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="2345" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s8_lsh" value="LSH Bucket Lookup&#xa;(locality-sensitive hashing —&#xa;find candidate near-duplicates fast)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d84315;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="430" y="2345" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s8_cosine" value="Cosine Similarity Check&#xa;(on lightweight embedding,&#xa;threshold ≥ 0.99 = duplicate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d84315;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="760" y="2345" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s8_merge" value="Merge Duplicate Metadata&#xa;(if dup found in another doc,&#xa;link source_documents array)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d84315;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1090" y="2345" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="s8_unique_set" value="Final De-duplicated&#xa;Chunk Set → proceed to embedding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d84315;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1420" y="2345" width="300" height="65" as="geometry"/>
                </mxCell>

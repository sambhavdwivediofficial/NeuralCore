                    <mxGeometry x="60" y="2500" width="1880" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="s9_batch" value="Batch Assembly&#xa;(group chunks into batches&#xa;of 100, provider API limit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#01579b;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="2545" width="260" height="65" as="geometry"/>
                </mxCell>

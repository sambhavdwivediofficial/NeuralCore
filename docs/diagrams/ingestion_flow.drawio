                    <mxGeometry x="60" y="2740" width="1880" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="s10_qdrant_upsert" value="Qdrant Upsert&#xa;(dense + sparse vectors,&#xa;payload = chunk metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2e7d32;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="2785" width="280" height="65" as="geometry"/>
